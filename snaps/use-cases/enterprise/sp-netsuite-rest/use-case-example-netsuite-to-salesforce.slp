from NetSuite to Salesforce. \n\nThis pipeline reads customer data using SuiteQL queries, specifically targeting data that was modified or newly created in the last day, and then synchronizes this data with Salesforce.","created":"2023-11-07T12:07:32.414Z","width":"493px","height":"395px","x":273.20001220703125,"y":36.8800048828125},"338482bf-5aa5-43b6-9106-5ecfe92f1066":{"creator":"John Doe","content":"","created":"2023-11-15T05:41:29.426Z","width":200,"height":150,"x":10,"y":10}}},"snap_map":{"b6818c01-73b3-4ffe-bc1c-c4b6f537e4e4":{"class_fqid":"com-snaplogic-snaps-netsuiterest-suiteqlexecute_1-435rc23598","class_id":"com-snaplogic-snaps-netsuiterest-suiteqlexecute","class_version":1,"instance_fqid":"b6818c01-73b3-4ffe-bc1c-c4b6f537e4e4_31","instance_id":"b6818c01-73b3-4ffe-bc1c-c4b6f537e4e4","instance_version":31,"property_map":{"info":{"label":{"value":"NetSuite REST Customer query"},"notes":{}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"errorOnNoResults":{"value":false},"paginationSettings":{"value":{"pages":{"value":1,"expression":false},"pageSize":{"value":10,"expression":false}}},"connection":{"value":{"readTimeout":{"value":60,"expression":false},"connTimeout":{"value":30,"expression":false}}},"retry":{"value":{"retryOn":{"value":"Server errors (5xx)"},"maxRetry":{"value":5,"expression":false},"retryInterval":{"value":3,"expression":false}}},"query":{"value":"\"SELECT Customer.id, Customer.phone, Customer.LastName, Customer.FirstName, Customer.altname, Customer.Email, Customer.lastmodifieddate as clastmodifieddate, EntityAddress.Addr1, EntityAddress.City, EntityAddress.State, EntityAddress.Country, EntityAddress.Zip, EntityAddress.lastmodifieddate as elastmodifieddate\nFROM Customer JOIN EntityAddress \nON \nCustomer.DefaultShippingAddress = En