ansform","class_version":4,"instance_fqid":"1bc7630a-6c7f-47b6-9f1f-3f28b71f550f_2","instance_id":"1bc7630a-6c7f-47b6-9f1f-3f28b71f550f","instance_version":2,"property_map":{"info":{"label":{"value":"Adding BuildTag"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"passThrough":{"value":true},"transformations":{"value":{"mappingRoot":{"value":"$"},"mappingTable":{"value":[{"expression":{"value":"_buildTag","expression":true},"targetPath":{"value":"class_build_tag"}}]}}},"nullSafeAccess":{"value":false}},"view_serial":100},"class_build_tag":"PR25347"},"9bd99493-2b8a-4f13-9540-d9179bf6fda5":{"class_fqid":"com-snaplogic-snaps-script-script_2-SNAPSHOT","class_id":"com-snaplogic-snaps-script-script","class_version":2,"instance_fqid":"9bd99493-2b8a-4f13-9540-d9179bf6fda5_5","instance_id":"9bd99493-2b8a-4f13-9540-d9179bf6fda5","instance_version":5,"property_map":{"info":{"label":{"value":"Account update"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"executable_during_suggest":{"value":false},"language":{"value":"Javascript"},"script":{"value":null,"expression":false},"editable_content":{"value":"// Ensure compatibility with both JDK 7 and 8 JSR-223 Script Engines\ntry { load(\"nashorn:mozilla_compat.js\"); } catch (e) { }\n\n// Import the interface required by the Script snap.\nimportPackage(com.snaplogic.scripting.language);\n\n// Import the serializable Java type we'll use for the output data.\nimportClass(java.util.LinkedHashMap);\nimportClass(java.util.ArrayList);\n\n/**\n * Create an object that implements the methods defined by the \"ScriptHook\"\n * interface.  We'll be passing this object to the constructor for the\n * ScriptHook interface.\n */\nvar impl = {\n    /*\n     * These variables (input, output, error, log) are defined by the\n     * ExecuteScript snap when evaluating this script.\n     */\n    input: input,\n    output: output,\n    error: error,\n    log: log,\n\n    /**\n     * The \"execute()\" method is called once when the pipeline is started\n     * and allowed to process its inputs or just send data to its outputs.\n     *\n     * Exceptions are automatically caught and sent to the error view.\n     */\n    execute: function () {\n        this.log.info(\"Executing Transform Script\");\n        while (this.input.hasNext()) {\n            try {\n                // Read the next input document, store it a new LinkedHashMap, and write this as an output document.\n                // We must use a serializable Java type liked LinkedHashMap for each output instead of a native\n                // JavaScript object so that downstream Snaps like Copy can process it correctly.\n                var inDoc = this.input.next();\n                var outDoc = new LinkedHashMap();\n                if (!inDoc.get(\"class_id\").contains(\"com-snaplogic-snaps-rest\") || inDoc.get(\"class_id\").contains(\"com-snaplogic-snaps-rest-restoauth1account\")) {\n                    continue;\n                }\n                var buidTag = inDoc.get(\"class_build_tag\");\n                inDoc.get(\"snap_pack\").put(\"_id\", \"apisuite-snap-1-\" + buidTag);\n                inDoc.get(\"snap_pack\").put(\"class_id\", \"apisuite\");\n                inDoc.get(\"snap_pack\").put(\"class_fqid\", \"apisuite-snap-1-\" + buidTag);\n                var propertyMap = inDoc.get(\"property_map\");\n                var settings = propertyMap.get(\"settings\");\n                if (inDoc.get(\"class_fqid\").contains(\"com-snaplogic-snaps-rest-restbasicauthaccount\")) {\n                    inDoc.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-accounts-basicauthaccount_1-\" + buidTag);\n                    inDoc.put(\"class_id\", \"com-snaplogic-snaps-apisuite-accounts-basicauthaccount\");\n                    inDoc.put(\"class_label\", \"Basic Authentication Account\");\n                } else if (inDoc.get(\"class_fqid\").contains(\"com-snaplogic-snaps-rest-restawsv4account\")) {\n                    inDoc.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-accounts-awssignaturev4account_1-\" + buidTag);\n                    inDoc.put(\"class_id\", \"com-snaplogic-snaps-apisuite-accounts-awssignaturev4account\");\n                    inDoc.put(\"class_label\", \"AWS Signature V4 Account\");\n                    settings.put(\"accessKey\", settings.get(\"accessKeyId\"));\n                    settings.remove(\"accessKeyId\");\n                    if (settings.get(\"region\") != null) {\n                        settings.put(\"awsRegion\", settings.get(\"region\"));\n                        settings.remove(\"region\");\n                    } else {\n                        var region = {\n                            \"value\" : null,\n                            \"expression\" : false\n                        }\n                        settings.put(\"awsRegion\", region);\n                    }\n                    if (settings.get(\"service\") != null) {\n                        settings.put(\"serviceName\", settings.get(\"service\"));\n                        settings.remove(\"service\");\n                    } else {\n                        var service = {\n                            \"value\" : null,\n                            \"expression\" : false\n                        }\n                        settings.put(\"serviceName\", service);\n                    }\n                    \n                } else if (inDoc.get(\"class_fqid\").contains(\"com-snaplogic-snaps-rest-restntlmaccount\")) {\n                    inDoc.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-accounts-ntlmaccount_1-\" + buidTag);\n                    inDoc.put(\"class_id\", \"com-snaplogic-snaps-apisuite-accounts-ntlmaccount\");\n                    inDoc.put(\"class_label\", \"NTLM Account\");\n                } else if (inDoc.get(\"class_fqid\").contains(\"com-snaplogic-snaps-rest-restoauth2account\")) {\n                    inDoc.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-accounts-httpoauth2account_1-\" + buidTag);\n                    inDoc.put(\"class_id\", \"com-snaplogic-snaps-apisuite-accounts-httpoauth2account\");\n                    inDoc.put(\"class_label\", \"OAuth2 Account\");\n                } else if (inDoc.get(\"class_fqid\").contains(\"com-snaplogic-snaps-rest-restinmemoryoauth2tokenaccount\")) {\n                    inDoc.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-accounts-httpoauth2account_1-\" + buidTag);\n                    inDoc.put(\"class_id\", \"com-snaplogic-snaps-apisuite-accounts-httpoauth2account\");\n                    inDoc.put(\"class_label\", \"OAuth2 Account\");\n                    settings.put(\"headerAuth\", { \"value\": true });\n                    settings.put(\"auth_endpoint\", settings.get(\"token_endpoint\"));\n                } else if (inDoc.get(\"class_fqid\").contains(\"com-snaplogic-snaps-rest-restssloauth2account\")) {\n                    inDoc.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-accounts-httpssloauth2account_1-\" + buidTag);\n                    inDoc.put(\"class_id\", \"com-snaplogic-snaps-apisuite-accounts-httpssloauth2account\");\n                    inDoc.put(\"class_label\", \"SSL OAuth2 Account\");\n                } else if (inDoc.get(\"class_fqid\").contains(\"com-snaplogic-snaps-rest-restsslaccount\")) {\n                    inDoc.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-accounts-sslauthaccount_1-\" + buidTag);\n                    inDoc.put(\"class_id\", \"com-snaplogic-snaps-apisuite-accounts-sslauthaccount\");\n                    inDoc.put(\"class_label\", \"SSL Account\");\n                } else if (inDoc.get(\"class_fqid\").contains(\"com-snaplogic-snaps-rest-restdynamicoauth2account\")) {\n                    inDoc.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-accounts-headerauthaccount_1-\" + buidTag);\n                    inDoc.put(\"class_id\", \"com-snaplogic-snaps-apisuite-accounts-headerauthaccount\");\n                    inDoc.put(\"class_label\", \"Secured Headers Account\");\n                    var authHeader = {\n                        \"value\": {\n                            \"scheme\": {\n                                \"value\": \"Bearer\",\n                                \"expression\": false\n                            },\n                            \"token\": {}\n                        }\n                    }\n                    var otherHeaders = new LinkedHashMap();\n                    otherHeaders.put(\"value\", new ArrayList());\n                    authHeader[\"value\"][\"token\"] = settings.get(\"access_token\");\n                    settings.put(\"authorizationHeader\", authHeader);\n                    settings.put(\"otherHeaders\", otherHeaders);\n                    settings.remove(\"access_token\");\n                }\n\n\n                outDoc.put(\"original\", inDoc);\n                this.output.write(inDoc, outDoc);\n            }\n            catch (err) {\n                var errDoc = new LinkedHashMap();\n                errDoc.put(\"error\", err);\n                this.log.error(err);\n                this.error.write(errDoc);\n            }\n        }\n        this.log.info(\"Script executed\");\n    },\n\n    /**\n     * The \"cleanup()\" method is called after the snap has exited the execute() method\n     */\n    cleanup: function () {\n        this.log.info(\"Cleaning up\")\n    }\n};\n\n\n\n/**\n * The Script Snap will look for a ScriptHook object in the \"hook\"\n * variable.  The snap will then call the hook's \"execute\" method.\n */\nvar hook = new com.snaplogic.scripting.language.ScriptHook(impl);\n"}},"view_serial":100},"class_build_tag":"SNAPSHOT"},"c7d7b4cf-561b-4447-aef6-3bcec562e6ee":{"class_fqid":"com-snaplogic-snaps-transform-datatransform_4-nov21p1","class_id":"com-snaplogic-snaps-transform-datatransform","class_version":4,"instance_fqid":"c7d7b4cf-561b-4447-aef6-3bcec562e6ee_7","instance_id":"c7d7b4cf-561b-4447-aef6-3bcec562e6ee","instance_version":7,"property_map":{"info":{"label":{"value":"Mapping metadata"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"passThrough":{"value":false},"transformations":{"value":{"mappingRoot":{"value":"$"},"mappingTable":{"value":[{"expression":{"expression":true,"value":"$original"},"targetPath":{"value":"$"}}]}}},"nullSafeAccess":{"value":false}},"view_serial":100},"class_build_tag":"nov21p1"},"9c6b9ec7-cb41-41ae-876a-1c6877d3b3a6":{"class_fqid":"com-snaplogic-snaps-flow-router_2-440patches29922","class_id":"com-snaplogic-snaps-flow-router","class_version":2,"instance_fqid":"9c6b9ec7-cb41-41ae-876a-1c6877d3b3a6_3","instance_id":"9c6b9ec7-cb41-41ae-876a-1c6877d3b3a6","instance_version":3,"property_map":{"info":{"label":{"value":"Router"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}},"output1":{"view_type":{"value":"document"},"label":{"value":"output1"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"f