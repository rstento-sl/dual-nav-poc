1c2-6158-4050-9017-b964510258db":{"grid_x_int":5,"grid_y_int":2,"rot_int":0,"recommendation_id":null,"source":"snap catagory","index":null,"rot_tail_int":0,"output":{"output1":{"rot_int":0,"dx_int":0,"dy_int":1}}},"508fce11-4bbe-4f11-a2c3-e7696a760b3c":{"grid_x_int":8,"grid_y_int":2,"rot_int":0,"recommendation_id":null,"source":"snap catagory","index":null,"rot_tail_int":0,"input":{"input1":{"rot_int":0,"dx_int":0,"dy_int":1}}}},"notes":{"5b19943a-2ef0-44cc-82b0-6a6191b25325":{"creator":"Sushma Sapa","content":"Snaplogic Metadata Read : Reads the selected pipeline metadata","created":"2024-03-07T03:13:29.315Z","width":"200px","height":"107px","x":37.030349703312226,"y":94.8759868699902},"65e67fb3-9056-4b8e-8022-51cd2c272606":{"creator":"Sushma Sapa","content":"Script snap : Updates the pipeline metadata to convert the snap from REST to HTTP Client","created":"2024-03-07T03:14:06.029Z","width":"250px","height":"130px","x":196.96573351340817,"y":82.720257553408},"5211ed48-b395-46b8-89ac-5c70b2db75ba":{"creator":"Sushma Sapa","content":"Router snap will decide whether to create new pipeline or update existing one based on createNew pipeline parameter","created":"2024-03-07T03:14:43.051Z","width":"200px","height":"148px","x":372.88047455908816,"y":72.63748976209854}}},"snap_map":{"a7081482-5e42-4f4b-a49e-6acc786c2d3c":{"class_fqid":"com-snaplogic-snaps-snaplogic-read_1-SNAPSHOT","class_id":"com-snaplogic-snaps-snaplogic-read","class_version":1,"instance_fqid":"a7081482-5e42-4f4b-a49e-6acc786c2d3c_1","instance_id":"a7081482-5e42-4f4b-a49e-6acc786c2d3c","instance_version":1,"property_map":{"info":{"label":{"value":"Pipeline Metadata Read"},"notes":{}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"normalized":{"value":false},"AssetType":{"value":"PIPELINE"},"AssetPath":{"value":"_path","expression":true},"strictPath":{"value":true}},"view_serial":100,"input":{}},"class_build_tag":"SNAPSHOT"},"e0f222a8-ba2e-45c3-9568-eb1c625044db":{"class_fqid":"com-snaplogic-snaps-transform-datatransform_4-PR25347","class_id":"com-snaplogic-snaps-transform-datatransform","class_version":4,"instance_fqid":"e0f222a8-ba2e-45c3-9568-eb1c625044db_1","instance_id":"e0f222a8-ba2e-45c3-9568-eb1c625044db","instance_version":1,"property_map":{"info":{"label":{"value":"Adding buildTag"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"passThrough":{"value":true},"transformations":{"value":{"mappingRoot":{"value":"$"},"mappingTable":{"value":[{"expression":{"value":"_buildTag","expression":true},"targetPath":{"value":"buildTag"}}]}}},"nullSafeAccess":{"value":false}},"view_serial":100},"class_build_tag":"PR25347"},"131e6a0c-5217-4c19-a054-30f7ff15cbca":{"class_fqid":"com-snaplogic-snaps-script-script_2-SNAPSHOT","class_id":"com-snaplogic-snaps-script-script","class_version":2,"instance_fqid":"131e6a0c-5217-4c19-a054-30f7ff15cbca_57","instance_id":"131e6a0c-5217-4c19-a054-30f7ff15cbca","instance_version":57,"property_map":{"info":{"label":{"value":"Update Metadata"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"executable_during_suggest":{"value":false},"language":{"value":"Javascript"},"script":{"value":null,"expression":false},"editable_content":{"value":"// Ensure compatibility with both JDK 7 and 8 JSR-223 Script Engines\ntry { load(\"nashorn:mozilla_compat.js\"); } catch (e) { }\n\n// Import the interface required by the Script snap.\nimportPackage(com.snaplogic.scripting.language);\n\n// Import the serializable Java type we'll use for the output data.\nimportClass(java.util.LinkedHashMap);\nimportClass(java.util.Map);\nimportClass(java.util.ArrayList);\n\n/**\n * Create an object that implements the methods defined by the \"ScriptHook\"\n * interface.  We'll be passing this object to the constructor for the\n * ScriptHook interface.\n */\nvar impl = {\n    /*\n     * These variables (input, output, error, log) are defined by the\n     * ExecuteScript snap when evaluating this script.\n     */\n    input: input,\n    output: output,\n    error: error,\n    log: log,\n\n    /**\n     * The \"execute()\" method is called once when the pipeline is started\n     * and allowed to process its inputs or just send data to its outputs.\n     *\n     * Exceptions are automatically caught and sent to the error view.\n     */\n    execute: function () {\n        this.log.info(\"Executing Transform Script\");\n        while (this.input.hasNext()) {\n            try {\n                // Read the next input document, store it a new LinkedHashMap, and write this as an output document.\n                // We must use a serializable Java type liked LinkedHashMap for each output instead of a native\n                // JavaScript object so that downstream Snaps like Copy can process it correctly.\n                var inDoc = this.input.next();\n                var buildTag = inDoc.get(\"buildTag\");\n                var snapMap = inDoc.get(\"snap_map\");\n                var outDoc = new LinkedHashMap();\n                var snapIDList = new ArrayList();\n                var isContainRest = false;\n                for (var key in snapMap) {\n                    var snap = snapMap.get(key);\n                    if (!snap.get(\"class_id\").contains(\"com-snaplogic-snaps-rest\")) {\n                        continue;\n                    }\n                    isContainRest = true;\n                    snapIDList.add(key);\n                    var propertyMap = snap.get(\"property_map\");\n                    defineSnapOutput(propertyMap.get(\"output\"));\n                    defineAccount(propertyMap.get(\"account\"));\n                    var settings = propertyMap.get(\"settings\");\n                    var method = {\n                        \"value\": \"\"\n                    };\n                    if (snap.get(\"class_id\") == \"com-snaplogic-snaps-rest-get\") {\n                        snap.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-httpclient_1-\" + buildTag);\n                        snap.put(\"class_id\", \"com-snaplogic-snaps-apisuite-httpclient\");\n                        method[\"value\"] = \"GET\";\n\n                    } else if (snap.get(\"class_id\") == \"com-snaplogic-snaps-rest-post\") {\n                        snap.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-httpclient_1-\" + buildTag);\n                        snap.put(\"class_id\", \"com-snaplogic-snaps-apisuite-httpclient\");\n                        method[\"value\"] = \"POST\";\n                    } else if (snap.get(\"class_id\") == \"com-snaplogic-snaps-rest-put\") {\n                        snap.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-httpclient_1-\" + buildTag);\n                        snap.put(\"class_id\", \"com-snaplogic-snaps-apisuite-httpclient\");\n                        method[\"value\"] = \"PUT\";\n                    } else if (snap.get(\"class_id\") == \"com-snaplogic-snaps-rest-patch\") {\n                        snap.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-httpclient_1-\" + buildTag);\n                        snap.put(\"class_id\", \"com-snaplogic-snaps-apisuite-httpclient\");\n                        method[\"value\"] = \"PATCH\";\n                    } else if (snap.get(\"class_id\") == \"com-snaplogic-snaps-rest-delete\") {\n                        snap.put(\"class_fqid\", \"com-snaplogic-snaps-apisuite-httpclient_1-\" + buildTag);\n                        snap.put(\"class_id\", \"com-snaplogic-snaps-apisuite-httpclient\");\n                        method[\"value\"] = \"DELETE\";\n                    }\n                    method[\"expression\"] = false;\n                    settings.put(\"httpMethod\", method);\n                    snap.put(\"class_build_tag\", buildTag);\n                    defineHttpEnity(settings);\n                    definePagination(settings);\n                    defineClientProps(settings);\n                    defineHeaders(settings);\n                    defineQueryParams(settings);\n                    settings.remove(\"rawData\");\n                    if (settings.get(\"showAllHeaders\") != null && settings.get(\"showAllHeaders\").get(\"value\") != null) {\n                        settings.put(\"enableDebug\", settings.get(\"showAllHeaders\"));\n                    } else {\n                        settings.put(\"enableDebug\", { \"value\": true });\n                    }\n                    settings.remove(\"showAllHeaders\");\n                    if (settings.get(\"serviceUrl\") != null) {\n                        settings.put(\"uri\", settings.get(\"serviceUrl\"));\n                        settings.remove(\"serviceUrl\");\n                    }\n\n                    if (settings.get(\"execution_mode\") == null) {\n                        var mode = {\n                            \"value\": \"Validate & Execute\"\n                        };\n                        settings.put(\"execution_mode\", mode);\n                    }\n                    //outDoc.put(key, snapMap.get(key));\n                }\n                inDoc.remove(\"buildTag\");\n                if (snapIDList.size() != 0) {\n                    updateLinks(inDoc, snapIDList);\n                    outDoc.put(\"original\", inDoc);\n                    this.output.write(inDoc, outDoc);\n                }\n            }\n            catch (err) {\n                var errDoc = new LinkedHashMap();\n                errDoc.put(\"error\", err);\n                this.log.error(err);\n                this.error.write(errDoc);\n            }\n        }\n        this.log.info(\"Script executed\");\n    },\n\n    /**\n     * The \"cleanup()\" method is called after the snap has exited the execute() method\n     */\n    cleanup: function () {\n        this.log.info(\"Cleaning up\")\n    }\n};\n\nfunction defineAccount(account) {\n    if (account != null) {\n        var accountRef = account.get(\"account_ref\");\n        if (accountRef != null && accountRef.get(\"value\") instanceof Map && accountRef.get(\"value\").get(\"ref_class_id\") != null) {\n            if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restbasicauthaccount\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"com-snaplogic-snaps-apisuite-accounts-basicauthaccount\");\n            } else if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restawsv4account\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"com-snaplogic-snaps-apisuite-accounts-awssignaturev4account\");\n            } else if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restdynamicoauth2account\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"com-snaplogic-snaps-apisuite-accounts-headerauthaccount\");\n            } else if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restinmemoryoauth2tokenaccount\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"com-snaplogic-snaps-apisuite-accounts-httpoauth2account\");\n            } else if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restntlmaccount\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"com-snaplogic-snaps-apisuite-accounts-ntlmaccount\");\n            } else if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restoauth1account\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"\");\n            } else if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restoauth2account\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"com-snaplogic-snaps-apisuite-accounts-httpoauth2account\");\n            } else if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restssloauth2account\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"com-snaplogic-snaps-apisuite-accounts-httpssloauth2account\");\n            } else if (accountRef.get(\"value\").get(\"ref_class_id\").get(\"value\") == \"com-snaplogic-snaps-rest-restsslaccount\") {\n                accountRef.get(\"value\").get(\"ref_class_id\").put(\"value\", \"com-snaplogic-snaps-apisuite-accounts-sslauthaccount\");\n            }\n        }\n    }\n\n}\n\nfunction defineSnapOutput(output) {\n    var outputResponse = {\n        \"view_type\": {\n            \"value\": \"document\"\n        },\n        \"label\": {\n            \"value\": \"Response\"\n        }\n    }\n    for (var key in output) {\n        output.remove(key);\n    }\n    output.put(\"outputResponse\", outputResponse);\n}\n\nfunction updateLinks(inDoc, snapIDList) {\n    var links = inDoc.get(\"link_map\");\n    for (var key in links) {\n        var link = links.get(key);\n        if (snapIDList.contains(link.get(\"src_id\"))) {\n            if (link.get(\"src_view_id\") != \"error0\") {\n                link.put(\"src_view_id\", \"outputResponse\");\n            }\n            if (link.get(\"dst_id\") != null) {\n                updateUpstreamSnap(link.get(\"dst_id\"), inDoc);\n            }\n        }\n    }\n    var outputMap = inDoc.get(\"property_map\").get(\"output\");\n    var restOutputMap = new LinkedHashMap();\n    for (var key in outputMap) {\n        var id = key.split(\"_\")[0];\n        if (snapIDList.contains(id)) {\n            restOutputMap.put(id + \"_outputResponse\", outputMap.get(key));\n        }\n    }\n\n    for (var key in restOutputMap) {\n        var id = key.split(\"_\")[0];\n        outputMap.put(id + \"_outputResponse\", outputMap.get(key));\n        outputMap.remove(key)\n    }\n}\n\nfunction updateUpstreamSnap(snapID, inDoc) {\n    var destSnap = inDoc.get(\"snap_map\").get(snapID);\n    var settings = destSnap.get(\"property_map\").get(\"settings\");\n    if (destSnap.get(\"class_id\").contains(\"datatransform\")) {\n        var mappings = settings.get(\"transformations\").get(\"value\").get(\"mappingTable\").get(\"value\");\n        if (mappings != null) {\n            for (var i in mappings) {\n                var mapping = mappings.get(i);\n                this.log.error(\"hello \" + mapping);\n                if (mapping.get(\"expression\").get(\"expression\") == true && mapping.get(\"expression\").get(\"value\") != null) {\n                    if (mapping.get(\"expression\").get(\"value\").contains(\"statusLine.reasonPhrase\")) {\n                        mapping.get(\"expression\").put(\"value\", mapping.get(\"expression\").get(\"value\").replaceAll(\"response.statusLine.reasonPhrase\", \"statusLine.statusText\"));\n                    } else if (mapping.get(\"expression\").get(\"value\").contains(\"statusLine.protoVersion\")) {\n                        mapping.get(\"expression\").put(\"value\", mapping.get(\"expression\").get(\"value\").replaceAll(\"response.statusLine.protoVersion\", \"statusLine.httpVersion\"));\n                    } else {\n                        mapping.get(\"expression\").put(\"value\", mapping.get(\"expression\").get(\"value\").replaceAll(\"response.\", \"\"));\n                    }\n                }\n            }\n        }\n    } else {\n        for (var name in settings) {\n            var prop = settings.get(name);\n            if (prop instanceof Map && prop.get(\"expression\") == true && prop.get(\"value\") instanceof String) {\n                prop.put(\"value\", prop.get(\"value\").replaceAll(\"response.\", \"\"));\n            }\n        }\n    }\n}\n\nfunction defineHttpEnity(settings) {\n    var isNoneType = true;\n    var httpEntity = {\n        \"value\": {\n            \"entityType\": {\n                \"value\": \"raw\"\n            },\n            \"rawEntity\": {\n                \"value\": \"$\",\n                \"expression\": true\n            },\n            \"multipartSubtype\": {\n                \"value\": \"form-data\",\n                \"expression\": false\n            },\n            \"multipartForm\": {\n                \"value\": []\n            },\n            \"urlEncodedForm\": {\n                \"value\": []\n            },\n            \"binaryFile\": {\n                \"value\": null,\n                \"expression\": false\n            }\n        }\n    };\n    var values = new ArrayList();\n    if (settings.get(\"uploadBodyType\") != null) {\n        if (settings.get(\"uploadBodyType\").get(\"value\") == 'Multipart form-data') {\n            if (settings.get(\"uploadFile\") != null && settings.get(\"uploadFile\").get(\"value\") != null) {\n                httpEntity[\"value\"][\"entityType\"][\"value\"] = \"multipart\";\n                isNoneType = false;\n                var newFile = {\n                    \"partType\": {\n                        \"value\": \"File\"\n                    },\n                    \"partKey\": {\n                        \"value\": null,\n                        \"expression\": false\n                    },\n                    \"partValue\": {\n                        \"value\": null,\n                        \"expression\": false\n                    },\n                    \"partContentType\": {\n                        \"value\": null,\n                        \"expression\": false\n                    }\n                };\n                newFile[\"partType\"][\"value\"] = \"File\";\n                if (settings.get(\"uploadFileKey\") != null && settings.get(\"uploadFileKey\").get(\"value\") != null) {\n                    newFile[\"partKey\"] = settings.get(\"uploadFileKey\")\n                } else {\n                    newFile[\"partKey\"][\"value\"] = \"file\";\n                }\n                newFile[\"partValue\"] = settings.get(\"uploadFile\")\n                newFile[\"partContentType\"] = settings.get(\"mimeType\")\n                values.add(newFile);\n                settings.remove(\"uploadFileKey\");\n                settings.remove(\"uploadFile\");\n                settings.remove(\"mimeType\");\n                settings.remove(\"uploadFileName\");\n            }\n\n            if (settings.get(\"uploadFiles\") != null) {\n                var files = settings.get(\"uploadFiles\").get(\"value\");\n                for (var i in files) {\n                    var file = files.get(i);\n                    if (file.get(\"uploadFile\") != null && file.get(\"uploadFile\").get(\"value\") != null) {\n                        httpEntity[\"value\"][\"entityType\"][\"value\"] = \"multipart\";\n                        isNoneType = false;\n                    }\n\n                    var newFile = {\n                        \"partType\": {\n                            \"value\": \"File\"\n                        },\n                        \"partKey\": {\n                            \"value\": null,\n                            \"expression\": false\n                        },\n                        \"partValue\": {\n                          