  newFile[\"partValue\"] = entity;\n    }\n\n    newFile[\"partContentType\"][\"value\"] = \"application/json\";\n    list.add(newFile);\n    newFile = {\n        \"partType\": {\n            \"value\": \"File\"\n        },\n        \"partKey\": {\n            \"value\": null,\n            \"expression\": false\n        },\n        \"partValue\": {\n            \"value\": null,\n            \"expression\": false\n        },\n        \"partContentType\": {\n            \"value\": null,\n            \"expression\": false\n        }\n    }\n    newFile[\"partType\"][\"value\"] = \"File\";\n    newFile[\"partKey\"] = uploadfileKey;\n    newFile[\"partValue\"] = uploadFile;\n    newFile[\"partContentType\"] = mimeType;\n    list.add(newFile);\n}\n\nfunction defineHeaders(settings) {\n    var headers = settings.get(\"header\");\n    var newHeaders = {\n        \"value\": []\n    };\n    if (headers != null) {\n        var headerArr = headers.get(\"value\");\n        var values = new ArrayList();\n\n        for (i in headerArr) {\n            var header = headerArr.get(i);\n            var newHeader = {\n                \"headerNameProp\": {\n                    \"value\": \"\"\n                },\n                \"headerValProp\": {\n                    \"value\": \"\"\n                }\n            }\n            newHeader[\"headerNameProp\"] = header.get(\"headerKey\");\n            newHeader[\"headerValProp\"] = header.get(\"headerValue\");\n            values.add(newHeader);\n        }\n        newHeaders[\"value\"] = values;\n    }\n\n    settings.put(\"header\", newHeaders);\n}\n\nfunction defineQueryParams(settings) {\n    var queryParams = settings.get(\"queryParams\")\n\n    var newqueryParams = {\n        \"value\": []\n    };\n    if (queryParams != null) {\n        var queryParamArr = queryParams.get(\"value\");\n        var values = new ArrayList();\n        var value = newqueryParams[\"value\"];\n        for (var i in queryParamArr) {\n            var queryParam = queryParamArr.get(i);\n            var newQueryParam = {\n                \"paramKeyProp\": {\n                    \"value\": \"\"\n                },\n                \"paramValProp\": {\n                    \"value\": \"\"\n                }\n            }\n            newQueryParam[\"paramKeyProp\"] = queryParam.get(\"queryParam\");\n            newQueryParam[\"paramValProp\"] = queryParam.get(\"queryParamValue\");\n            values.add(newQueryParam);\n        }\n        newqueryParams[\"value\"] = values;\n        if (values.size() > 0) {\n            settings.put(\"formEncodeSpace\", { \"value\": true, \"expression\": false });\n        }\n    }\n    \n    settings.put(\"queryParam\", newqueryParams);\n    settings.remove(\"queryParams\");\n}\n\n\nfunction defineClientProps(settings) {\n    var clientProperties = {\n        \"value\": {\n            \"connection\": {\n                \"value\": {\n                    \"cookiePolicy\": {\n                        \"value\": \"RFC Lax\"\n                    },\n                    \"readTimeout\": {\n                        \"value\": 900\n                    },\n                    \"connTimeout\": {\n                        \"value\": 30\n                    },\n                    \"trustAllCerts\": {\n                        \"value\": false\n                    },\n                    \"diskStagingProp\": {\n                        \"value\": false\n                    }\n                }\n            },\n            \"retry\": {\n                \"value\": {\n                    \"retryCondition\": {\n                        \"value\": \"Connection Errors\"\n                    },\n                    \"maxRetry\": {\n                        \"value\": 5\n                    },\n                    \"retryInterval\": {\n                        \"value\": 3\n                    },\n                    \"autoRetry429\": {\n                        \"value\": true\n                    },\n                    \"useRetryAfterHeader\": {\n                        \"value\": true\n                    }\n                }\n            },\n            \"redirects\": {\n                \"value\": {\n                    \"followRedirection\": {\n                        \"value\": true\n                    },\n                    \"maxRedirect\": {\n                        \"value\": 10,\n                        \"expression\": false\n                    },\n                    \"allowRelativeRedirect\": {\n                        \"value\": true\n                    },\n                    \"allowCircularRedirect\": {\n                        \"value\": false\n                    },\n                    \"followOriginalMethod\": {\n                        \"value\": false\n                    }\n                }\n            },\n            \"outputProps\": {\n                \"value\": {\n                    \"responseType\": {\n                        \"value\": \"JSON\"\n                    },\n                    \"extractEntityPath\": {\n                        \"value\": \"\",\n                        \"expression\": true\n                    },\n                    \"errorRespToErrorview\": {\n                        \"value\": true\n                    },\n                    \"extractEntity\": {\n                        \"value\": false\n                    },\n                    \"includeCookies\": {\n                        \"value\": false\n                    }\n                }\n            }\n        }\n    };\n    if (settings.get(\"cookiePolicy\") != null && settings.get(\"cookiePolicy\").get(\"value\") != null) {\n        if (settings.get(\"cookiePolicy\").get(\"value\").toUpperCase(\"IGNORE COOKIES\")) {\n            clientProperties[\"value\"][\"connection\"][\"value\"][\"cookiePolicy\"][\"value\"] = \"Ignore Cookies\"\n        } else if (settings.get(\"cookiePolicy\").get(\"value\").toUpperCase(\"BROWSER COMPATIBILITY\")) {\n            clientProperties[\"value\"][\"connection\"][\"value\"][\"cookiePolicy\"][\"value\"] = \"Browser Compatibility\";\n        } else if (settings.get(\"cookiePolicy\").get(\"value\").toUpperCase(\"RFC STRICT\")) {\n            clientProperties[\"value\"][\"connection\"][\"value\"][\"cookiePolicy\"][\"value\"] = \"RFC Strict\";\n        } else if (settings.get(\"cookiePolicy\").get(\"value\").toUpperCase(\"RFC LAX\")) {\n            clientProperties[\"value\"][\"connection\"][\"value\"][\"cookiePolicy\"][\"value\"] = \"RFC Lax\";\n        }\n    }\n    if (settings.get(\"timeout\") != null && settings.get(\"timeout\").get(\"value\") != null) {\n        clientProperties[\"value\"][\"connection\"][\"value\"][\"readTimeout\"] = settings.get(\"timeout\");\n    }\n    if (settings.get(\"connTimeout\") != null && settings.get(\"connTimeout\").get(\"value\") != null) {\n        clientProperties[\"value\"][\"connection\"][\"value\"][\"connTimeout\"] = settings.get(\"connTimeout\");\n    }\n    if (settings.get(\"trustAllCerts\") != null && settings.get(\"trustAllCerts\").get(\"value\") != null) {\n        clientProperties[\"value\"][\"connection\"][\"value\"][\"trustAllCerts\"] = settings.get(\"trustAllCerts\");\n    }\n    if (settings.get(\"retry\") != null && settings.get(\"retry\").get(\"value\") != null) {\n        clientProperties[\"value\"][\"retry\"][\"value\"][\"maxRetry\"] = settings.get(\"retry\");\n    }\n    if (settings.get(\"retryInterval\") != null && settings.get(\"retryInterval\").get(\"value\") != null) {\n        clientProperties[\"value\"][\"retry\"][\"value\"][\"retryInterval\"] = settings.get(\"retryInterval\");\n    }\n    if (settings.get(\"followRedirects\") != null && settings.get(\"followRedirects\").get(\"value\") != null) {\n        clientProperties[\"value\"][\"redirects\"][\"value\"][\"followRedirection\"] = settings.get(\"followRedirects\");\n    }\n\n    if (settings.get(\"responseEntityType\") != null) {\n        if (settings.get(\"responseEntityType\").get(\"value\") == 'BINARY') {\n            clientProperties[\"value\"][\"outputProps\"][\"value\"][\"responseType\"][\"value\"] = \"Raw\";\n        } else if (settings.get(\"responseEntityType\").get(\"value\") == 'TEXT') {\n            clientProperties[\"value\"][\"outputProps\"][\"value\"][\"responseType\"][\"value\"] = \"Text\";\n        } else {\n            clientProperties[\"value\"][\"outputProps\"][\"value\"][\"responseType\"][\"value\"] = \"JSON\";\n            if (settings.get(\"processArray\") != null) {\n                clientProperties[\"value\"][\"outputProps\"][\"value\"][\"extractEntity\"] = settings.get(\"processArray\");\n            }\n        }\n    }\n    if (settings.get(\"retryPolicy\") != null) {\n        if (settings.get(\"retryPolicy\").get(\"value\") == \"Connection errors\") {\n            clientProperties[\"value\"][\"retry\"][\"value\"][\"retryCondition\"][\"value\"] = \"Connection Errors\";\n        } else if (settings.get(\"retryPolicy\").get(\"value\") == \"Connection and auth errors (401/403)\") {\n            clientProperties[\"value\"][\"retry\"][\"value\"][\"retryCondition\"][\"value\"] = \"Connection Errors and Auth Errors (401/403)\";\n        } else if (settings.get(\"retryPolicy\").get(\"value\") == \"Connection and client errors (4xx)\") {\n            clientProperties[\"value\"][\"retry\"][\"value\"][\"retryCondition\"][\"value\"] = \"Connection Errors and Client Errors (4xx)\";\n        } else if (settings.get(\"retryPolicy\").get(\"value\") == \"Connection and server errors (5xx)\") {\n            clientProperties[\"value\"][\"retry\"][\"value\"][\"retryCondition\"][\"value\"] = \"Connection Errors and Server Errors (5xx)\";\n        } else {\n            clientProperties[\"value\"][\"retry\"][\"value\"][\"retryCondition\"][\"value\"] = \"All Errors\";\n        }\n    }\n    settings.put(\"clientProperties\", clientProperties);\n    settings.remove(\"cookiePolicy\");\n    settings.remove(\"timeout\");\n    settings.remove(\"connTimeout\");\n    settings.remove(\"trustAllCerts\");\n    settings.remove(\"retry\");\n    settings.remove(\"retryInterval\");\n    settings.remove(\"retryPolicy\");\n\n    settings.remove(\"followRedirects\");\n    settings.remove(\"responseEntityType\");\n\n}\n\nfunction definePagination(settings) {\n    var pagination = {\n        \"value\": {\n            \"paginationInterval\": {\n                \"value\": 0\n            },\n            \"hasNext\": {\n                \"expression\": true,\n                \"value\": \"\"\n            },\n            \"nextUrl\": {\n                \"expression\": true,\n                \"value\": null\n            },\n            \"maxPage\": {\n                \"value\": null,\n                \"expression\": false\n            },\n            \"overrideURI\": {\n                \"value\": false\n            },\n            \"reuseParamsForPagination\": {\n                \"value\": false\n            }\n        }\n    };\n    if (settings.get(\"hasNext\") != null && settings.get(\"hasNext\").get(\"value\") != null) {\n        var hasNextVal = settings.get(\"hasNext\").get(\"value\");\n        if (hasNextVal.contains(\"snap.out.totalCount\")) {\n            hasNextVal = hasNextVal.replaceAll(\"snap.out.totalCount\", \"(snap.out.totalCount+1)\");\n        }\n        pagination[\"value\"][\"hasNext\"][\"expression\"] = settings.get(\"hasNext\").get(\"expression\");\n        pagination[\"value\"][\"hasNext\"][\"value\"] = hasNextVal;\n    }\n    if (settings.get(\"paginationInterval\") != null && settings.get(\"paginationInterval\").get(\"value\") != null) {\n        pagination[\"value\"][\"paginationInterval\"] = settings.get(\"paginationInterval\");\n    }\n    if (settings.get(\"nextUrl\") != null && settings.get(\"nextUrl\").get(\"value\") != null) {\n        var nextURLVal = settings.get(\"nextUrl\").get(\"value\");\n        if (nextURLVal.contains(\"snap.out.totalCount\")) {\n            nextURLVal = nextURLVal.replaceAll(\"snap.out.totalCount\", \"(snap.out.totalCount+1)\");\n        }\n        pagination[\"value\"][\"nextUrl\"][\"expression\"] = settings.get(\"nextUrl\").get(\"expression\");\n        pagination[\"value\"][\"nextUrl\"][\"value\"] = nextURLVal;\n        pagination[\"value\"][\"overrideURI\"][\"value\"] = true;\n        pagination[\"value\"][\"maxPage\"][\"value\"] = 0;\n    }\n    settings.put(\"pagination\", pagination);\n    settings.remove(\"hasNext\");\n    settings.remove(\"paginationInterval\");\n    settings.remove(\"nextUrl\");\n}\n\n/**\n * The Script Snap will look for a ScriptHook object in the \"hook\"\n * variable.  The snap will then call the hook's \"execute\" method.\n */\nvar hook = new com.snaplogic.scripting.language.ScriptHook(impl);\n"}},"view_serial":100},"class_build_tag":"SNAPSHOT"},"14a1c858-b033-4d03-b095-763f4d8fee36":{"class_fqid":"com-snaplogic-snaps-transform-datatransform_4-nov21p1","class_id":"com-snaplogic-snaps-transform-datatransform","class_version":4,"instance_fqid":"14a1c858-b033-4d03-b095-763f4d8fee36_35","instance_id":"14a1c858-b033-4d03-b095-763f4d8fee36","instance_version":35,"property_map":{"info":{"label":{"value":"Read  metadata"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"passThrough":{"value":false},"transformations":{"value":{"mappingRoot":{"value":"$"},"mappingTable":{"value":[{"expression":{"expression":true,"value":"$original"},"targetPath":{"value":"$"}}]}}},"nullSafeAccess":{"value":false}},"view_serial":100},"class_build_tag":"nov21p1"},"4b70e122-15e2-4e5d-8a09-6d42f18bc2f4":{"class_fqid":"com-snaplogic-snaps-snaplogic-create_1-SNAPSHOT","class_id":"com-snaplogic-snaps-snaplogic-create","class_versio