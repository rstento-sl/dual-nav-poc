{"class_fqid":"com-snaplogic-pipeline_9","snode_id":"63c044406f92b4309221ee3e","instance_id":"11fe9f7b-e2cc-48ac-a9fd-a35fbf304b4a","instance_version":8,"link_map":{"link103":{"src_view_id":"output0","dst_view_id":"input0","src_id":"32fb86b3-aa7f-48de-88ac-f7e6c252f797","dst_id":"b10be095-ed8c-49ef-867d-c282ac5d2289","isGoto":false}},"link_serial":104,"property_map":{"info":{"notes":{"value":null},"author":{"value":"admin@snaplogic.com"},"purpose":{"value":null},"pipeline_doc_uri":{"value":null},"label":{"value":"Copy of Sort_de10567"}},"input":{},"settings":{"param_table":{"value":[]}},"error":{"error_behavior":{"value":"none"}},"output":{"b10be095-ed8c-49ef-867d-c282ac5d2289_output0":{"label":{"value":"Sort - output0"},"view_type":{"value":"document"}}}},"render_map":{"pan_x_num":0,"default_snaplex":"564ba566c734595eb065ae3b","scale_ratio":1,"detail_map":{"32fb86b3-aa7f-48de-88ac-f7e6c252f797":{"grid_x_int":2,"index":null,"recommendation_id":null,"source":"snap catagory","grid_y_int":2,"rot_tail_int":0,"rot_int":0},"b10be095-ed8c-49ef-867d-c282ac5d2289":{"grid_x_int":3,"rot_int":0,"grid_y_int":2,"rot_tail_int":0}},"pan_y_num":0},"snap_map":{"32fb86b3-aa7f-48de-88ac-f7e6c252f797":{"class_fqid":"com-snaplogic-snaps-transform-jsongenerator_2-100","class_id":"com-snaplogic-snaps-transform-jsongenerator","class_version":2,"instance_fqid":"32fb86b3-aa7f-48de-88ac-f7e6c252f797_4","instance_id":"32fb86b3-aa7f-48de-88ac-f7e6c252f797","instance_version":4,"property_map":{"info":{"label":{"value":"JSON Generator"}},"view_serial":100,"error":{"error0":{"label":{"value":"error0"},"view_type":{"value":"document"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}},"settings":{"supportTypeExts":{"value":false},"execution_mode":{"value":"Validate & Execute"},"editable_content":{"value":"## Enter your JSON-encoded data in this space.  Note that this text is\n## treated as an Apache Velocity template, so you can substitute values\n## from input documents or the pipeline parameters.  See the following\n## URL for more information about Velocity:\n##   https://velocity.apache.org/engine/devel/user-guide.html\n\n[\n  {\n    \"ID\" : \"a2m1400000KAathAAD\",\n    \"LatName\" : \"Murray\",\n    \"FirstName\" : \"Steve\",\n    \"Country\" : \"USA\",\n    \"City\" : \"New York\",\n    \"Age\" : 23\n  },\n  {\n    \"ID\" : \"a2m1400000KAbPzAAL\",\n    \"LatName\" : \"Chang\",\n    \"FirstName\" : \"Kai\",\n    \"Country\" : \"China\",\n    \"City\" : \"Shanghai\",\n    \"Age\" : 33\n  },\n  {\n    \"ID\" : \"a2m1400000KAbQ0AAL\",\n    \"LatName\" : \"Pancholy\",\n    \"FirstName\" : \"Rajiv\",\n    \"Country\" : \"India\",\n    \"City\" : \"New Delhi\",\n    \"Age\" : 66\n  },\n  {\n    \"ID\" : \"a2m1400000KAbQ1AAL\",\n    \"LatName\" : \"Kim\",\n    \"FirstName\" : \"Youngsu\",\n    \"Country\" : \"Korea\",\n    \"City\" : \"Seoul\",\n    \"Age\" : 23\n  },\n  {\n    \"ID\" : \"a2m1400000KAbQ2AAL\",\n    \"LatName\" : \"Harris\",\n    \"FirstName\" : \"David\",\n    \"Country\" : \"United Kingdom\",\n    \"City\" : \"London\",\n    \"Age\" : 33\n  }\n]\n\n\n## Tips:\n##  * The sample data above will generate a single empty document, uncomment\n##    the line in the middle to include the sample fields.  Adding more\n##    objects to the root array will cause the snap to generate more\n##    than one document.\n##  * Pipeline parameters can be referenced by prefixing the parameter\n##    name with an underscore, like so:\n##      ${_pipelineParamName}\n##  * If you add an input view to the snap, this template will be\n##    evaluated for each input document.\n##  * Fields in the input documents can be referenced by prefixing them\n##    with a dollar-sign ($), like so:\n##      $parent.child[0].value\n##  * Any referenced document values and pipeline parameters will\n##    automatically be JSON-encoded when they are inserted into the final\n##    JSON document.  You should not have to worry about escaping values\n##    yourself.\n##  * If you are having troubles getting a template to produce valid JSON,\n##    you can add an error view to the snap to get a document that\n##    contains the output of the template evaluation.\n"},"arrayElementsAsDocuments":{"value":true},"passThroughProp":{"value":false}}},"class_build_tag":"100"},"b10be095-ed8c-49ef-867d-c282ac5d2289":{"class_fqid":"com-snaplogic-snaps-transform-sort_2-transform1905","class_id":"com-snaplogic-snaps-transform-sort","class_version":2,"instance_fqid":"b10be095-ed8c-49ef-867d-c282ac5d2289_4","instance_id":"b10be095-ed8c-49ef-867d-c282ac5d2289","instance_version":4,"property_map":{"info":{"notes":{"value":null},"label":{"value":"Sort"}},"view_serial":100,"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"document"}}},"settings":{"sortPaths":{"value":[{"sortPath":{"value":"$Age"},"sortOrderInd":{"value":"descending"}},{"sortPath":{"value":"$Last"},"sortOrderInd":{"value":"global"}}]},"execution_mode":{"value":"Validate & Execute"},"nullGreater":{"value":false},"nullSafeAccess":{"value":true},"maxMemoryPercentage":{"value":1},"sortOrder":{"value":"ascending"}},"error":{"error0":{"label":{"value":"error0"},"view_type":{"value":"document"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}}},"class_build_tag":"transform1905"}},"path_id":"/snaplogic/shared","path_snode":"634eed08f9f3fccc73abb35a","target_runtime":"standard"}