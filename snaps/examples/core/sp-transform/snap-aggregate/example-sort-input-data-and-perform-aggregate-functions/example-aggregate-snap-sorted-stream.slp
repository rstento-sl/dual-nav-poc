recommendation_id":null,"source":"snap catagory","index":null,"rot_tail_int":0,"input":{},"output":{},"error":{}},"a95831c6-a6bd-4854-9336-09868e1c82be":{"grid_x_int":5,"grid_y_int":1,"rot_int":0,"recommendation_id":null,"source":"snap catagory","index":null,"rot_tail_int":0,"input":{},"output":{},"error":{}},"7a560566-cd8d-44ba-b088-5b0bad436ed1":{"grid_x_int":4,"grid_y_int":1,"rot_int":0,"recommendation_id":null,"source":"snap catagory","index":null,"rot_tail_int":0,"input":{},"output":{},"error":{}}},"notes":{"b9b8a4ff-3d7e-444e-9a6d-04a0565ec453":{"creator":" ","content":"In this sample pipeline, the input documents for Aggregate Snap has two fields: 'value' and 'group'.\nThe output of Mapper Snap produces 20 million input documents for Aggregate Snap.\nThe 'value' field ranges from 1 through 20 million sorted, and the 'group' values are random numbers between 1 through 10 million, unsorted.\nNote that the 'GROUP-By field' property in Aggregate Snap has $group, and it means that we want Aggregate Snap to group input documents per the $group value.","created":"2024-02-21T22:29:33.033Z","width":"718px","height":"185px","x":17.52974214516786,"y":81.28163459186693},"651aedd9-dffc-4817-b9d6-617a7bba6138":{"creator":" ","content":"If the input document stream into Aggregate Snap were not sorted, Aggregate Snap can cause out-of-memory error if the plex has limited available memory. This is because the Snap needs a random access to all 20-million input documents in order to process the GROUP-By function.\nTherefore, it is important to use Sort Snap to pre-sort the input document on $group so that Aggregate Snap do not have to use too much memory and can read input documents of the same group, process their aggregate functions and write an output document for that group.","created":"2024-02-21T23:04:47.544Z","width":"721px","height":"208px","x":17.02775874007574,"y":179.16841390414785}}},"snap_map":{"dd19520a-4b27-4822-bd52-b3d06363fe13":{"class_fqid":"com-snaplogic-snaps-transform-sequence_1-SNAPSHOT","class_id":"com-snaplogic-snaps-transform-sequence","class_version":1,"instance_fqid":"dd19520a-4b27-4822-bd52-b3d06363fe13_1","instance_id":"dd19520a-4b27-4822-bd52-b3d06363fe13","instance_version":1,"property_map":{"info":{"label":{"value":"Sequence"},"notes":{}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"initialValueProp":{"value":1,"expression":false},"stepValueProp":{"value":1,"expression":false},"numberOfDocumentsProp":{"value":"_NumDocs","expression":true},"passThroughProp":{"value":false}},"view_serial":100,"input":{}},"class_build_tag":"SNAPSHOT"},"c31951e6-78f8-4a36-b456-efbefde1e642":{"class_fqid":"com-snaplogic-snaps-transform-datatransform_4-SNAPSHOT","class_id":"com-snaplogic-snaps-transform-datatransform","class_version":4,"instance_fqid":"c31951e6-78f8-4a36-b456-efbefde1e642_1","instance_id":"c31951e6-78f8-4a36-b456-efbefde1e642","instance_version":1,"property_map":{"info":{"label":{"value":"Mapper"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"passThrough":{"value":false},"transformations":{"value":{"mappingRoot":{"value":"$"},"mappingTable":{"value":[{"expression":{"expression":true,"value":"$value"},"targetPath":{"value":"value"}},{"expression":{"value":"Math.floor(Math.random() * _NumGroups)","expression":true},"targetPath":{"value":"group"}}]}}},"nullSafeAccess":{"value":false}},"view_serial":100},"class_build_tag":"SNAPSHOT"},"a95831c6-a6bd-4854-9336-09868e1c82be":{"class_fqid":"com-snaplogic-snap