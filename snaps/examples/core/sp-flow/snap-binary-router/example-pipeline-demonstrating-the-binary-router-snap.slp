 into the final\n##    JSON document.  You should not have to worry about escaping values\n##    yourself.\n##  * If you are having troubles getting a template to produce valid JSON,\n##    you can add an error view to the snap to get a document that\n##    contains the output of the template evaluation."},"arrayElementsAsDocuments":{"value":false}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"},"data_uris":null,"header_uris":null,"snap_schema_fqid":{"instance_id":"3fcc7e9f-34b0-4aa8-ab37-30a754198b43","output_view_id":"error0"}},"error_behavior":{"value":"fail"}}},"class_build_tag":"snapsmrc140"},"dd51142c-975a-424b-ab78-8d79148721a4":{"class_fqid":"com-snaplogic-snaps-transform-jsonsplitter_1-snapsmrc140","class_id":"com-snaplogic-snaps-transform-jsonsplitter","class_version":1,"instance_fqid":"dd51142c-975a-424b-ab78-8d79148721a4_3","instance_id":"dd51142c-975a-424b-ab78-8d79148721a4","instance_version":3,"property_map":{"info":{"notes":{"value":null},"label":{"value":"JSON Splitter"}},"view_serial":100,"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"document"}}},"settings":{"nullSafeAccess":{"value":false},"includeParents":{"value":false},"includePaths":{"value":[]},"path":{"value":"$"}},"error":{"error0":{"label":{"value":"error0"},"view_type":{"value":"document"},"data_uris":null,"header_uris":null,"snap_schema_fqid":{"instance_id":"3fcc7e9f-34b0-4aa8-ab37-30a754198b43","output_view_id":"output0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}}},"class_build_tag":"snapsmrc140"}},"path_id":"/snaplogic/projects/Rich","path_snode":"533333eb640a9a5ebe7b4597"}