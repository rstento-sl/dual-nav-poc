tting a template to produce valid JSON,\n##    you can add an error view to the snap to get a document that\n##    contains the output of the template evaluation."},"arrayElementsAsDocuments":{"value":true}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}}},"class_build_tag":"0002"},"f2cc2626-fee1-4390-8ff5-6a7727e9a1be":{"class_fqid":"com-snaplogic-snaps-binary-pgpdecrypt_2-snapsmrc140","class_id":"com-snaplogic-snaps-binary-pgpdecrypt","class_version":2,"instance_fqid":"f2cc2626-fee1-4390-8ff5-6a7727e9a1be_1","instance_id":"f2cc2626-fee1-4390-8ff5-6a7727e9a1be","instance_version":1,"property_map":{"info":{"notes":{"value":null},"label":{"value":"PGP Decrypt"}},"view_serial":100,"account":{"account_ref":{"value":{"label":{"value":"PGP - Private - Decrypt"},"ref_class_id":{"value":"com-snaplogic-snaps-binary-pgpprivatekeyaccount"},"ref_id":{"value":"c53d4968-0a8b-4bd2-8476-4d0326928f9e"}}}},"input":{"input0":{"view_type":{"value":"binary"},"label":{"value":"input0"}}},"settings":{},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"header_uris":["__suggest__/96b89ae2-785b-46b7-b127-ed6b075df29d/54534453a8fe7d0fac3e6e73_50a90e87-9fd0-446b-a84b-116ba03442d7_f2cc2626-fee1-4390-8ff5-6a7727e9a1be_output_output0-header-data-binary0.dat"],"data_uris":["__suggest__/96b89ae2-785b-46b7-b127-ed6b075df29d/54534453a8fe7d0fac3e6e73_50a90e87-9fd0-446b-a84b-116ba03442d7_f2cc2626-fee1-4390-8ff5-6a7727e9a1be_output_output0-data-binary0.dat"],"view_type":{"value":"binary"},"label":{"value":"output0"}}}},"class_build_tag":"snapsmrc140"},"f54d758c-c57d-4aef-be3a-8a42af6017b4":{"class_fqid":"com-snaplogic-snaps-transform-jsonformatter_2-0002","class_id":"com-snaplogic-snaps-transform-jsonformatter","class_version":2,"instance_fqid":"f54d758c-c57d-4aef-be3a