{"class_fqid":"com-snaplogic-pipeline_9","snode_id":"68dfa783ec9eaefb88e7631d","instance_id":"8a8fb459-40cc-41c2-be81-cd68fd792d66","instance_version":6,"link_map":{},"link_serial":100,"property_map":{"info":{"label":{"value":"Pyspark_Linux"},"author":{"value":"apallamala@snaplogic.com"},"pipeline_doc_uri":{"value":null},"notes":{"value":null},"purpose":{"value":null}},"error":{"error_behavior":{"value":"none"}},"settings":{"suspendable":{"value":false},"error_pipeline":{"value":null,"expression":false},"error_param_table":{"value":[]},"param_table":{"value":[]},"imports":{"value":[]}},"input":{},"output":{"d028a369-4747-47f0-9f23-d24a644a2d68_output0":{"view_type":{"value":"document"},"label":{"value":"PySpark - output0"}}}},"render_map":{"scale_ratio":1,"pan_x_num":0,"pan_y_num":0,"default_snaplex":"638f06a44994d16482eeb5eb","detail_map":{"d028a369-4747-47f0-9f23-d24a644a2d68":{"grid_x_int":4,"grid_y_int":1,"rot_int":0,"recommendation_id":null,"source":"","index":null,"rot_tail_int":0,"input":{}}}},"snap_map":{"d028a369-4747-47f0-9f23-d24a644a2d68":{"class_fqid":"com-snaplogic-snaps-script-pyspark_1-syed28aug25a","class_id":"com-snaplogic-snaps-script-pyspark","class_version":1,"instance_fqid":"d028a369-4747-47f0-9f23-d24a644a2d68_4","instance_id":"d028a369-4747-47f0-9f23-d24a644a2d68","instance_version":4,"property_map":{"info":{"label":{"value":"PySpark"},"notes":{}},"input":{},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"sparkSubmitCmd":{"value":"spark-submit"},"scriptArgs":{"value":null,"expression":false},"execution_mode":{"value":"Validate & Execute"},"timeoutSec":{"value":-1,"expression":false},"sparkSubmitArgs":{"value":"file:///opt/test.py","expression":false},"executable_during_suggest":{"value":false},"sparkHome":{"value":"/opt/spark/spark-3.5.6-bin-hadoop3","expression":false},"editable_content":{"value":"### PySpark Word Count script template ###\n################################################################\n# If you are not familiar with Spark Programming,              #\n# please check Spark programming guide for more detail.        #\n# http://spark.apache.org/docs/latest/programming-guide.html   #\n################################################################\n\nimport sys\nfrom operator import add\n\nfrom pyspark import SparkContext\n\nif __name__ == \"__main__\":\n    if len(sys.argv) < 3:\n        print >> sys.stderr, \"Usage: wordcount <master> <file>\"\n        exit(-1)\n    sc = SparkContext()\n    lines = sc.textFile(sys.argv[2], 1)\n    counts = lines.flatMap(lambda x: x.split(' ')) \\\n                  .map(lambda x: (x, 1)) \\\n                  .reduceByKey(add)\n    output = counts.collect()\n    for (word, count) in output:\n        print \"%s: %i\" % (word, count)"},"yarnRM":{"value":null,"expression":false}},"account":{"account_ref":{"value":{}}},"view_serial":100},"class_build_tag":"syed28aug25a"}},"path_id":"/snap_automation/qa_diagnostic_space/ent_diagnostic","path_snode":"60373e08a74a2c7ce5c74b17"}