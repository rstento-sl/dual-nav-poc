oot":{"value":"$"}}}},"error":{"error0":{"label":{"value":"error0"},"view_type":{"value":"document"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}}},"class_build_tag":"snapsrc315"},"679b54b2-3063-4595-bbbd-b2bea1547dbe":{"class_fqid":"com-snaplogic-snaps-flow-copy_1-snapsrc315","class_id":"com-snaplogic-snaps-flow-copy","class_version":1,"instance_fqid":"679b54b2-3063-4595-bbbd-b2bea1547dbe_3","instance_id":"679b54b2-3063-4595-bbbd-b2bea1547dbe","instance_version":3,"property_map":{"info":{"notes":{"value":null},"label":{"value":"Copy"}},"view_serial":102,"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"settings":{"execution_mode":{"value":"Validate & Execute"}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}},"output1":{"view_type":{"value":"document"},"label":{"value":"output1"}},"output101":{"view_type":{"value":"document"},"label":{"value":"output2"}}}},"class_build_tag":"snapsrc315"},"70eefac9-acc0-4332-8312-1ba399d74c64":{"class_fqid":"com-snaplogic-snaps-script-script_2-snapsrc315","class_id":"com-snaplogic-snaps-script-script","class_version":2,"instance_fqid":"70eefac9-acc0-4332-8312-1ba399d74c64_5","instance_id":"70eefac9-acc0-4332-8312-1ba399d74c64","instance_version":5,"property_map":{"info":{"notes":{"value":null},"label":{"value":"JS Script"}},"view_serial":102,"input":{"input101":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"settings":{"language":{"value":"Javascript"},"editable_content":{"value":"script = {\n            execute : function()\n            {\n                while (input.hasNext())\n                {\n                    var data2 = input.next();\n                    var new_data = {};\n\n                    var keyArray = data2.keySet().toArray();\n                    for( var index in keyArray) \n                        {\n                            var key = keyArray[index];\n                            new_data[key] = data2.get(key);\n                        }\n                    \n                    new_data.firstLast = new_data.first + \"-\" + new_data.last;\n                    new_data.firstLast2 = new_data.first + data2.get(\"last\");\n                    new_data.numberMath = new_data.counter.longValue() + 22;\n                    new_data.numberMath2 = parseInt(new_data.counter) + 23;\n                    new_data.dateMath = new_data.birthday.plusMonths(1).toString();\n                    \n                    new_data.mathType = typeof(new_data.counter);                        \n                    new_data.dateType = typeof(new_data.birthday);\n                    \n\n                  function badFunction() \n                      {\n                            \n                       }\n\n                   try\n                      {\n                            new_data.tryval = badFunction(new_data.birthday);\n                        \n                            new_data.tryBlock = \"success\";\n                            output.write(new_data);\n                      }\n                    catch(err)\n                      {\n                            new_data.errMsg = err.message;\n                            new_data.tryBlock = \"failed\";\n                            error.write(new_data);\n                      }\n                     \n                     \n\n\n\n                      \n                }\n            }   \n        };\n\nvar hook = new com.snaplogic.scripting.language.ScriptHook(script)"},"execution_mode":{"value":"Validate & Execute"},"executable_during_suggest":{"value":true},"script":{"expression":false,"value":null}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output102":{"view_type":{"value":"document"},"label":{"value":"output0"}}}},"class_build_tag":"snapsrc315"},"1dd2337f-6f54-441d-b1f2-a887234506d2":{"class_fqid":"com-snaplogic-snaps-transform-jsonsplitter_1-snapsrc315","class_id":"com-snaplogic-snaps-transform-jsonsplitter","class_version":1,"instance_fqid":"1dd2337f-6f54-441d-b1f2-a887234506d2_1","instance_id":"1dd2337f-6f54-441d-b1f2-a887234506d2","instance_version":1,"property_map":{"info":{"notes":{"value":null},"label":{"value":"JSON Splitter"}},"view_serial":100,"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"document"}}},"settings":{"includeParents":{"value":false},"path":{"value":"$"}},"error":{"error0":{"label":{"value":"error0"},"view_type":{"value":"document"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}}},"class_build_tag":"snapsrc315"},"ed15dd60-981b-43d5-a015-1952ce176e55":{"class_fqid":"com-snaplogic-snaps-script-script_2-snapsrc315","class_id":"com-snaplogic-snaps-script-script","class_version":2,"instance_fqid":"ed15dd60-981b-43d5-a015-1952ce176e55_5","instance_id":"ed15dd60-981b-43d5-a015-1952ce176e55","instance_version":5,"property_map":{"info":{"notes":{"value":null},"label":{"value":"Python Script"}},"view_serial":102,"input":{"input102":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"settings":{"language":{"value":"Python"},"editable_content":{"value":"from com.snaplogic.scripting.language import ScriptHook\nfrom com.snaplogic.scripting.language.ScriptHook import *\n\nclass TransformScript(ScriptHook):\n    def __init__(self, input, output, error, log):\n        self.input = input\n        self.output = output\n        self.error = error\n        self.log = log\n\n    def execute(self):\n        self.log.info(\"Executing Transform script\")\n        \n        while self.input.hasNext():\n            data = self.input.next()\n            data[\"firstLast\"] = \"%s-%s\" %(data[\"first\"],data[\"last\"])\n            data[\"firstLast2\"] = data[\"first\"] + data[\"last\"]\n            \n            data[\"numberMath\"] = data[\"counter\"] + 22\n            data[\"numberMath2\"] = data[\"counter\"] + 23\n\n            data[\"dateMonthPlusOne\"] = data[\"birthday\"].plusMonths(1)\n            \n            data[\"numberMathType\"] = type(data[\"counter\"])\n            data[\"dateType\"] = type(data[\"birthday\"])\n    \n            \n\n            try:\n                data[\"mathTryCatch\"] = data[\"counter2\"] + 33\n                self.output.write(data)\n            except Exception as e:\n                data[\"errorMessage\"] = e.message\n                self.error.write(data)\n            \n            \n        self.log.info(\"Finished executing the Transform script\") \n \nhook = TransformScript(input, output, error, log)"},"execution_mode":{"value":"Validate & Execute"},"executable_during_suggest":{"value":true},"script":{"expression":false,"value":null}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output101":{"view_type":{"value":"document"},"label":{"value":"output0"}}}},"class_build_tag":"snapsrc315"},"9a16e2cb-da10-4df9-afbb-573502642792":{"class_fqid":"com-snaplogic-snaps-script-script_2-snapsrc315","class_id":"com-snaplogic-snaps-script-script","class_version":2,"instance_fqid":"9a16e2cb-da10-4df9-afbb-573502642792_5","instance_id":"9a16e2cb-da10-4df9-afbb-573502642792","instance_version":5,"property_map":{"info":{"notes":{"value":null},"label":{"value":"Ruby Script"}},"view_serial":102,"input":{"input101":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"settings":{"executable_during_suggest":{"value":true},"editable_content":{"value":"class MyScript\n    include com.snaplogic.scripting.language.ScriptHook\n    attr_reader :log, :input, :output, :error\n    def initialize(log, input, output, error)\n        @log = log\n        @input = input\n        @output = output\n        @error = error\n        @array = [java.lang.Integer.valueOf(1), java.lang.Integer.valueOf(2)]\n        \n        \n    end\n\n    def execute()\n  \n  \n  \n        while input.hasNext()  do\n          data = input.next()\n        \n        \n      \n            data[\"firstLast2\"] = data[\"first\"] + data[\"last\"]\n            \n            data[\"numberMath\"] = data[\"counter\"] + 22\n            data[\"numberMath2\"] = data[\"counter\"] + 23\n            data[\"dateMonthPlusOne\"] = data[\"birthday\"].plusMonths(1)\n   \n\n\n            begin\n                data[\"mathTryCatch\"] = data[\"counter\"] + 33\n                output.write(data)\n            rescue Exception=>e\n                data[\"errorMessage\"] = e.message\n                error.write(data)\n            end\n        end\n\n\n    end \nend\n$hook = MyScript.new($log, $input, $output, $error)"},"execution_mode":{"value":"Validate & Execute"},"language":{"value":"Ruby"},"script":{"expression":false,"value":null}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output102":{"view_type":{"value":"document"},"label":{"value":"output0"}}}},"class_build_tag":"snapsrc315"},"e9c14c8c-c290-4717-961e-e95ef489c431":{"class_fqid":"com-snaplogic-snaps-transform-jsongenerator_2-snapsrc315","class_id":"com-snaplogic-snaps-transform-jsongenerator","class_version":2,"instance_fqid":"e9c14c8c-c290-4717-961e-e95ef489c431_1","instance_id":"e9c14c8c-c290-4717-961e-e95ef489c431","instance_version":1,"property_map":{"info":{"notes":{"value":null},"label":{"value":"JSON Generator"}},"view_serial":100,"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}}},"settings":{"editable_content":{"value":"[{\"first\":\"John\",\"last\":\"Smith\",\"birthday\":\"1984-03-02T01:52:33.000+08:00\",\"counter\":0},{\"first\":\"Peter\",\"last\":\"Pan\",\"birthday\":\"1985-04-02T01:52:33.000+08:00\",\"counter\":1},{\"first\":\"Robin\",\"last\":\"Hood\",\"birthday\":\"1987-06-02T01:52:33.000+08:00\",\"counter\":2},{\"first\":\"Angry\",\"last\":\"Birds\",\"birthday\":\"1989-09-02T01:52:33.000+08:00\",\"counter\":3}]"},"arrayElementsAsDocuments":{"value":false}}},"class_build_tag":"snapsrc315"}},"path_id":"/snaplogic/projects/shared","path_snode":"64ccc76ec44091232c0eb7b5","target_runtime":"standard"}